{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "types": ["node"],

    "baseUrl": ".",

    "paths": {
      "@pages/*": ["src/pages/*"],
      "@components/*": ["src/components/*"],
      "@tests/*": ["tests/*"],
      "@data/*": ["test-data/*"],
      "@models/*": ["src/models/*"]
    },

    "ignoreDeprecations": "6.0"
  }
}