{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "types": ["node"],

    "baseUrl": ".",

  "paths": {
    "@pages/*": ["src/pages/*"],
    "@components/*": ["src/components/*"],
    "@tests/*": ["tests/*"],
    "@data/*": ["test-data/*"],
    "@models/*": ["src/models/*"],

    "@api/*": ["src/api/*"],

    "@clients/*": ["src/api/clients/*"],
    "@services/*": ["src/api/services/*"],
    "@builders/*": ["src/api/builders/*"],
    "@validators/*": ["src/api/validators/*"],
    "@contracts/*": ["src/api/contracts/*"],
    "@fixtures/*": ["src/api/fixtures/*"],
    "@auth/*": ["src/api/auth/*"],
    "@utils/*": ["src/api/utils/*"],
    "@framework-utils/*": ["src/utils/*"],
    "@/*": ["src/*"],
    "@execution/*": ["src/core/execution/*"],
  },

    "ignoreDeprecations": "6.0"
  }
}